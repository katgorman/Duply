FIRESTORE_PRODUCTS_COLLECTION=beauty_products
FIRESTORE_CACHE_TTL_SECONDS=900
FIRESTORE_SEARCH_CACHE_TTL_SECONDS=300

# Recommendation engine mode:
# auto = try local model, fall back if unavailable
# disabled = always use metadata-only fallback ranking
# DUPLY_MODEL_MODE=disabled

# Choose one Firebase credential method for hosted deployments.

# Option 1: Path to a service account JSON file on the server.
# GOOGLE_APPLICATION_CREDENTIALS=/etc/secrets/firebase-service-account.json

# Option 2: Inline the entire service account JSON as one secret env var.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project-id","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/..."}

# Option 3: Split the JSON into separate env vars.
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"
